# ---------------------------------------------------------------------------
# Development environment — do NOT commit real secrets here.
# ---------------------------------------------------------------------------

# Prefix for client-side API calls.
# In dev (npm run dev): /api  → requests are handled by app/api/ route proxies,
#                               which forward to FastAPI at BACKEND_URL.
# In production build (npm run build / NEXT_STATIC=1): leave blank so the
# static export calls FastAPI directly at the same origin (e.g. /investigate).
NEXT_PUBLIC_API_BASE=/api

# FastAPI backend — used by app/api/ route handlers (server-side only, never
# exposed to the browser). Change if FastAPI is running on a different port.
BACKEND_URL=http://localhost:8000
