# Prefix for client-side API calls.
# In dev (npm run dev): points to FastAPI at localhost:8000 (CORS is open).
# In production (npm run build / NEXT_STATIC=1): leave blank so the
# static export calls FastAPI directly at the same origin (e.g. /investigate).
NEXT_PUBLIC_API_BASE=http://localhost:8000
